# Provider keys and OpenRouter/MiniMax attribution
DEEPSEEK_API_KEY=your-deepseek-api-key
OPENROUTER_API_KEY=
MINIMAX_API_KEY=
# OPENROUTER_SITE_URL=https://your-app.example.com
# OPENROUTER_X_TITLE=OS ChatBot
# OPENROUTER_HTTP_REFERER=https://your-app.example.com
# OPENROUTER_APP_TITLE=OS ChatBot
# These values are read from env at startup and can also be overridden later from Settings.

# Session and login protection
FLASK_SECRET_KEY=change-this-to-a-long-random-secret
# SECRET_KEY=change-this-to-a-long-random-secret
# LOGIN_PIN=1234
# LOGIN_SESSION_TIMEOUT_MINUTES=30
# LOGIN_MAX_FAILED_ATTEMPTS=3
# LOGIN_LOCKOUT_SECONDS=300
# LOGIN_REMEMBER_SESSION_DAYS=3650

# HTTPS, reverse proxy, and transport security
# TRUST_PROXY_HEADERS=true
# FORCE_HTTPS=true
# SESSION_COOKIE_SECURE=true
# PREFERRED_URL_SCHEME=https
# SECURITY_HSTS_ENABLED=true
# SECURITY_HSTS_MAX_AGE=31536000
# SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
# SECURITY_HSTS_PRELOAD=false
# SECURITY_RATE_LIMIT_REDIS_ENABLED=false
# SECURITY_RATE_LIMIT_REDIS_URL=redis://localhost:6379/0

# Runtime and storage
# AGENT_TRACE_LOG_ENABLED=true
# AGENT_TRACE_LOG_INCLUDE_RAW=true
# AGENT_TRACE_LOG_PATH=./logs/agent-trace.log

# Centralized application logging
# APP_LOG_ENABLED=true
# APP_LOG_LEVEL=INFO (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# APP_LOG_PATH=./logs/app.log
# APP_LOG_MAX_BYTES=2097152
# APP_LOG_BACKUP_COUNT=5
# APP_LOG_CONSOLE_ENABLED=false

# IMAGE_STORAGE_DIR=./data/images
# DOCUMENT_STORAGE_DIR=./data/documents
# PROJECT_WORKSPACE_ROOT=./data/workspaces
# SCRATCHPAD_ADMIN_EDITING_ENABLED=false
# CANVAS_PROMPT_DEFAULT_MAX_LINES=250
# CANVAS_PROMPT_DEFAULT_MAX_TOKENS=4000
# CANVAS_PROMPT_DEFAULT_MAX_CHARS=20000
# CANVAS_PROMPT_CODE_LINE_MAX_CHARS=180
# CANVAS_PROMPT_TEXT_LINE_MAX_CHARS=100
# CANVAS_EXPAND_DEFAULT_MAX_LINES=1600
# CANVAS_SCROLL_WINDOW_LINES=200

# Feature toggles
# RAG_ENABLED=true
# OCR_ENABLED=true
# OCR_PROVIDER=paddleocr
# OCR_PRELOAD=true
# CONVERSATION_MEMORY_ENABLED=true
# YOUTUBE_TRANSCRIPTS_ENABLED=false

# RAG and embedding (env defaults/seeds; many runtime values can be overridden in Settings)
# BGE_M3_MODEL_PATH=./models/rag/bge-m3
# BGE_M3_DEVICE=cpu
# BGE_M3_LOCAL_FILES_ONLY=false
# BGE_M3_TRUST_REMOTE_CODE=false
# BGE_M3_BATCH_SIZE=32
# BGE_M3_PRELOAD=true
# RAG_AUTO_INJECT_TOP_K=3
# RAG_SEARCH_DEFAULT_TOP_K=5
# RAG_AUTO_INJECT_THRESHOLD=0.50
# RAG_SEARCH_MIN_SIMILARITY=0.35
# RAG_CHUNK_SIZE=1800
# RAG_CHUNK_OVERLAP=250
# RAG_MAX_CHUNKS_PER_SOURCE=2
# RAG_QUERY_EXPANSION_ENABLED=true
# RAG_QUERY_EXPANSION_MAX_VARIANTS=2
# RAG_TEMPORAL_DECAY_ALPHA=0.15
# RAG_TEMPORAL_DECAY_LAMBDA=0.05

# YouTube transcript extraction (env defaults/seeds; runtime values can be overridden in Settings)
# YOUTUBE_TRANSCRIPT_MODEL_SIZE=small
# YOUTUBE_TRANSCRIPT_DEVICE=auto
# YOUTUBE_TRANSCRIPT_COMPUTE_TYPE=int8
# YOUTUBE_TRANSCRIPT_DEFAULT_LANGUAGE=

# Tool memory retention defaults (env defaults/seeds; runtime values can be overridden in Settings)
# TOOL_MEMORY_TTL_DEFAULT_SECONDS=604800
# TOOL_MEMORY_TTL_WEB_SECONDS=43200
# TOOL_MEMORY_TTL_NEWS_SECONDS=7200

# Fetch, summarization, prompt, and pruning baselines
# FETCH_SUMMARY_TOKEN_THRESHOLD=3500
# FETCH_SUMMARY_MAX_CHARS=8000
# FETCH_SUMMARY_GENERAL_TOP_K=3
# FETCH_SUMMARY_QUERY_TOP_K=4
# FETCH_SUMMARY_EXCERPT_MAX_CHARS=500
# FETCH_SUMMARIZE_MAX_INPUT_CHARS=80000
# FETCH_SUMMARIZE_MAX_OUTPUT_TOKENS=2400
# FETCH_RAW_TOOL_RESULT_MAX_TEXT_CHARS=24000
# CHAT_SUMMARY_TRIGGER_TOKEN_COUNT=80000
# CHAT_SUMMARY_MODE=auto
# CHAT_SUMMARY_MODEL=deepseek-chat
# PROMPT_MAX_INPUT_TOKENS=100000
# PROMPT_RESPONSE_TOKEN_RESERVE=8000
# PROMPT_RECENT_HISTORY_MAX_TOKENS=70000
# PROMPT_SUMMARY_MAX_TOKENS=15000
# PROMPT_RAG_MAX_TOKENS=6000
# PROMPT_RAG_AUTO_MAX_TOKENS=3000
# PROMPT_TOOL_TRACE_MAX_TOKENS=500
# PROMPT_TOOL_MEMORY_MAX_TOKENS=1500
# PROMPT_PREFLIGHT_SUMMARY_TOKEN_COUNT=90000
# AGENT_CONTEXT_COMPACTION_THRESHOLD=0.85
# AGENT_CONTEXT_COMPACTION_KEEP_RECENT_ROUNDS=2
# AGENT_TOOL_RESULT_TRANSCRIPT_MAX_CHARS=16000
# SUMMARY_SOURCE_TARGET_TOKENS=6000
# SUMMARY_RETRY_MIN_SOURCE_TOKENS=1500
# SUMMARY_RETRY_REDUCTION_FACTOR=0.80
# PRUNING_TARGET_REDUCTION_RATIO=0.65
# PRUNING_MIN_TARGET_TOKENS=160
# PRUNE_WEIGHT_ENTROPY=0.35
# PRUNE_WEIGHT_RAG=0.30
# PRUNE_WEIGHT_STALENESS=0.25
# PRUNE_WEIGHT_TOKEN=0.10
# Most of these env values act as startup defaults and may later be overridden from Settings.
